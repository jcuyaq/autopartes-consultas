{
  "info": {
    "name": "Autopartes - Reportes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://192.168.10.76:9010",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/health",
          "host": ["{{base_url}}"],
          "path": ["api", "health"]
        }
      }
    },
    {
      "name": "Cuentas por Cobrar",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/cuentas-por-cobrar",
          "host": ["{{base_url}}"],
          "path": ["api", "cuentas-por-cobrar"]
        }
      }
    }
  ]
}
